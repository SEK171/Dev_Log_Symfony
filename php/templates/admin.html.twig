{% extends 'base.html.twig' %}

{% block title %}Admin Panel - Log Manager{% endblock %}

{% block body %}
<div class="content">
    <div class="page-title">
        <div class="wrap">
            <h2>Admin Panel</h2>
        </div>
    </div>

    <div class="block">
        {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
        {% endfor %}
        
        {% for message in app.flashes('error') %}
            <div class="alert alert-error">{{ message }}</div>
        {% endfor %}

        <div class="warning">
            <strong>Warning:</strong> Uploading a new log will delete all existing logs and tasks.
            {% if pendingTasks > 0 %}
                <p>There are {{ pendingTasks }} unresolved tasks 
                ({{ criticalTasks }} critical issues).</p>
            {% endif %}
        </div>

        <h3>Update Log File</h3>
        {{ form_start(uploadForm, {'attr': {'enctype': 'multipart/form-data'}}) }}
            {{ form_row(uploadForm.logfile) }}
            {{ form_row(uploadForm.submit) }}
        {{ form_end(uploadForm) }}
    </div>
</div>
{% endblock %}